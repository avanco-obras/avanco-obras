# ──────────────────────────────────────────────
# DATABASE
# Desenvolvimento: postgresql://avanco:avanco_secret@localhost:5432/avanco_obras
# Produção (Supabase): postgresql://postgres:<senha>@db.<projeto>.supabase.co:5432/postgres
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://avanco:avanco_secret@localhost:5432/avanco_obras
DB_PASSWORD=avanco_secret

# ──────────────────────────────────────────────
# JWT — troque por valores longos e aleatórios em produção
# ──────────────────────────────────────────────
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ──────────────────────────────────────────────
# OBJECT STORAGE
# Desenvolvimento (MinIO local): endpoint=localhost, port=9000, useSSL=false
# Produção (Cloudflare R2):      endpoint=<id>.r2.cloudflarestorage.com, port=, useSSL=true
# ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=avanco-obras
MINIO_USE_SSL=false

# ──────────────────────────────────────────────
# REDIS
# Desenvolvimento: redis://localhost:6379
# Produção (Upstash): rediss://<token>@<host>.upstash.io:6379
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# CORS_ORIGINS: lista separada por vírgula das origens permitidas
# Produção: adicione a URL do Vercel, ex: https://avanco-obras.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:80
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# IA (opcional)
# ──────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
